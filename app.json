{
  "expo": {
    "name": "MyCEO",
    "slug": "MyCEO",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "myceo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.webskitters.myceo",
      "icon": "./src/assets/images/ios-icon.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow MyCEO to capture your location after login."
      },
      "supportsTablet": true
    },
    "android": {
      "icon": "./src/assets/images/android-icon.png",
      "package": "com.webskitters.myceo",
      "adaptiveIcon": {
        "backgroundColor": "#020914",
        "foregroundImage": "./src/assets/images/android-icon-foreground.png",
        "backgroundImage": "./src/assets/images/android-icon-background.png",
        "monochromeImage": "./src/assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#020914",
          "dark": {
            "backgroundColor": "#020914"
          }
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
